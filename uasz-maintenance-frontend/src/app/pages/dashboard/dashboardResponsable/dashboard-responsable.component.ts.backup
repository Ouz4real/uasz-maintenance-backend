  // Profile methods
  resetProfilForm(): void {
    this.profilForm = {
      motDePasseActuel: '',
      nouveauMotDePasse: '',
      confirmationMotDePasse: ''
    };
    this.showCurrentPassword = false;
    this.showNewPassword = false;
    this.showConfirmPassword = false;
  }

  enregistrerProfil(): void {
    // Implementation for saving profile
    console.log('Enregistrement du profil:', this.profilForm);
  }

  mettreAJourMotDePasse(): void {
    // Implementation for updating password
    if (this.profilForm.nouveauMotDePasse !== this.profilForm.confirmationMotDePasse) {
      this.showErrorToast('Les mots de passe ne correspondent pas');
      return;
    }
    
    if (!this.profilForm.motDePasseActuel || !this.profilForm.nouveauMotDePasse) {
      this.showErrorToast('Veuillez remplir tous les champs');
      return;
    }

    // Call API to update password
    console.log('Mise à jour du mot de passe');
    this.showSuccessToast('Mot de passe mis à jour avec succès');
    this.resetProfilForm();
  }

