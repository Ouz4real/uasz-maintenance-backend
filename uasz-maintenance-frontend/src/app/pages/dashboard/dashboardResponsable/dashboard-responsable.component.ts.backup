  private chargerDemandesDepuisApi(): void {
    this.pannesRespApi.getAllPannes().subscribe({
      next: (pannes) => {
        console.log('✅ Pannes chargées:', pannes);
        this.demandes = pannes.map(panne => ({
          ...panne,
          urgenceDemandeur: panne.priorite || 'MOYENNE',
          statut: panne.statut,
          dateCreation: panne.dateSignalement || panne.dateCreation || panne.createdAt
        }));
        this.mesDemandes = [...this.demandes];
        this.appliquerFiltre();
        this.calculateStatistics();
        this.generateDemandesParMois();
      },
      error: (error) => {
        console.error('❌ Erreur lors du chargement des pannes:', error);
        this.showErrorToast('Erreur lors du chargement des demandes');
      }
    });
  }

  private chargerTechniciens(): void {
    this.techniciensService.getTechniciens().subscribe({
      next: (techniciens) => {
        console.log('✅ Techniciens chargés:', techniciens);
        this.techniciens = techniciens.map(tech => ({
          ...tech,
          fullName: `${tech.prenom || ''} ${tech.nom || ''}`.trim() || tech.username,
          disponible: true // Par défaut
        }));
        this.filteredTechniciens = [...this.techniciens];
        this.techniciensActifs = [...this.techniciens];
      },
      error: (error) => {
        console.error('❌ Erreur lors du chargement des techniciens:', error);
        this.showErrorToast('Erreur lors du chargement des techniciens');
      }
    });
  }

  loadMaintenancesPreventives(): void {
    this.preventivesService.getAll().subscribe({
      next: (maintenances) => {
        console.log('✅ Maintenances préventives chargées:', maintenances);
        this.maintenancesPreventives = maintenances;
        this.filteredMaintenancesPreventives = [...this.maintenancesPreventives];
        this.paginatedMaintenancesPreventives = [...this.maintenancesPreventives];
        this.applyPreventiveFilter();
        
        // Calculer les statistiques
        this.nbPreventivesPlanifiees = maintenances.filter(m => m.statut === 'PLANIFIEE').length;
        this.nbPreventivesEnRetard = maintenances.filter(m => m.statut === 'EN_RETARD').length;
        this.nbPreventivesRealisees = maintenances.filter(m => m.statut === 'REALISEE').length;
      },
      error: (error) => {
        console.error('❌ Erreur lors du chargement des maintenances préventives:', error);
        this.showErrorToast('Erreur lors du chargement des maintenances préventives');
      }
    });
  }

