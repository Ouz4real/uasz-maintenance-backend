  // Badge and status methods
  badgeClassIntervention(statut: string): string {
    switch (statut?.toUpperCase()) {
      case 'EN_ATTENTE':
        return 'badge-warning';
      case 'EN_COURS':
        return 'badge-info';
      case 'TERMINEE':
        return 'badge-success';
      case 'ANNULEE':
        return 'badge-danger';
      default:
        return 'badge-secondary';
    }
  }

  libelleStatutIntervention(statut: string): string {
    switch (statut?.toUpperCase()) {
      case 'EN_ATTENTE':
        return 'En attente';
      case 'EN_COURS':
        return 'En cours';
      case 'TERMINEE':
        return 'Terminée';
      case 'ANNULEE':
        return 'Annulée';
      default:
        return statut || 'Inconnu';
    }
  }

  // Urgence methods
  getUrgencePillClass(urgence: string): string {
    switch (urgence?.toUpperCase()) {
      case 'HAUTE':
        return 'urgence-haute';
      case 'MOYENNE':
        return 'urgence-moyenne';
      case 'BASSE':
        return 'urgence-basse';
      default:
        return 'urgence-normale';
    }
  }

  getUrgenceLabel(urgence: string): string {
    switch (urgence?.toUpperCase()) {
      case 'HAUTE':
        return 'Haute';
      case 'MOYENNE':
        return 'Moyenne';
      case 'BASSE':
        return 'Basse';
      default:
        return urgence || 'Normale';
    }
  }

  // Compare functions for select elements
  compareUrgence(o1: any, o2: any): boolean {
    return o1 && o2 ? o1 === o2 : o1 === o2;
  }

  compareById(o1: any, o2: any): boolean {
    return o1 && o2 ? o1.id === o2.id : o1 === o2;
  }

  // Safe image lightbox method
  openImageLightboxSafe(imageUrl: string | null): void {
    if (imageUrl) {
      this.openImageLightbox(this.getSafeImageUrl(imageUrl));
