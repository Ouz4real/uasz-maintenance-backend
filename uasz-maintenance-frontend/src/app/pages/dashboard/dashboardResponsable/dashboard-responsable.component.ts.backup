  }

  isCreateStockInvalid(): boolean {
    return !this.createStockForm.type || this.createStockForm.quantite <= 0;
  }

  normalizeStockQuantity(): void {
    // Ensure quantity is a positive number
    if (this.createStockForm.quantite < 0) {
      this.createStockForm.quantite = 0;
    }
    // Convert to integer if it's a decimal
    this.createStockForm.quantite = Math.floor(this.createStockForm.quantite);
  }

