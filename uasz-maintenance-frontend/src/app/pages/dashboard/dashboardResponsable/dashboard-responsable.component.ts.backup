  createStockTypeWithQuantity(): void {
    if (this.createStockForm.type && this.createStockForm.quantite > 0) {
      // Implementation for creating stock type with quantity
      console.log('Création du stock:', this.createStockForm);
      this.showSuccessToast('Équipement ajouté avec succès');
