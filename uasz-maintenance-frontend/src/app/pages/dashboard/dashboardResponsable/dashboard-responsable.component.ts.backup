  // Méthodes de pagination
  goToPage(page: number): void {
    if (page >= 1 && page <= this.totalPages) {
      this.currentPage = page;
      this.appliquerFiltre();
    }
  }

  // Méthodes pour les filtres
  changerFiltreStatutSignalements(statut: string): void {
    this.filtreStatutSignalements = statut;
    this.statusFilter = statut as any;
    this.currentPage = 1; // Reset à la première page
    this.appliquerFiltre();
  }

  onUrgenceFilterChange(urgence: string): void {
    this.urgenceFilter = urgence;
    this.filtreUrgence = urgence as any;
    this.currentPage = 1; // Reset à la première page
    this.appliquerFiltre();
  }

