  private trierDemandesParStatut(demandes: any[]): any[] {
    const ordre = {
      'EN_ATTENTE': 1,
      'EN_COURS': 2,
      'RESOLUE': 3,
      'ANNULEE': 4,
      'DECLINEE': 5
    };

    return demandes.sort((a, b) => {
      const ordreA = ordre[a.statut as keyof typeof ordre] || 999;
      const ordreB = ordre[b.statut as keyof typeof ordre] || 999;
      
      if (ordreA !== ordreB) {
        return ordreA - ordreB;
      }
      
      // Si même statut, trier par priorité
      const prioriteOrdre = { 'HAUTE': 1, 'MOYENNE': 2, 'BASSE': 3 };
      const prioriteA = prioriteOrdre[a.priorite as keyof typeof prioriteOrdre] || 999;
      const prioriteB = prioriteOrdre[b.priorite as keyof typeof prioriteOrdre] || 999;
      
      if (prioriteA !== prioriteB) {
        return prioriteA - prioriteB;
      }
      
      // Si même priorité, trier par date (plus récent en premier)
      return new Date(b.dateCreation).getTime() - new Date(a.dateCreation).getTime();
    });
  }

  appliquerFiltre(): void {
    let demandesFiltrees = [...this.demandes];

    // Filtre par statut
    if (this.statusFilter !== 'TOUTES') {
      demandesFiltrees = demandesFiltrees.filter(d => d.statut === this.statusFilter);
    }

    // Filtre par statut signalements
    if (this.filtreStatutSignalements !== 'TOUS') {
      demandesFiltrees = demandesFiltrees.filter(d => d.statut === this.filtreStatutSignalements);
    }

    // Filtre par urgence
    if (this.filtreUrgence !== 'TOUTES') {
      demandesFiltrees = demandesFiltrees.filter(d => d.urgenceDemandeur === this.filtreUrgence);
    }

    // Filtre par urgence (autre propriété)
    if (this.urgenceFilter !== 'TOUTES') {
      demandesFiltrees = demandesFiltrees.filter(d => d.urgenceDemandeur === this.urgenceFilter);
    }

    this.filteredDemandes = demandesFiltrees;
    
    // Mise à jour de la pagination
    this.totalPages = Math.ceil(this.filteredDemandes.length / this.pageSize);
    this.totalPagesArray = Array.from({length: this.totalPages}, (_, i) => i + 1);
    
    // Calcul des indices de pagination
    this.pageStartIndex = (this.currentPage - 1) * this.pageSize + 1;
    this.pageEndIndex = Math.min(this.currentPage * this.pageSize, this.filteredDemandes.length);
    
    // Données paginées
    const startIndex = (this.currentPage - 1) * this.pageSize;
    const endIndex = startIndex + this.pageSize;
    this.paginatedDemandes = this.filteredDemandes.slice(startIndex, endIndex);

    // Mise à jour des données "mes demandes"
    this.mesDemandesFiltrees = [...demandesFiltrees];
    const mesStartIndex = (this.mesCurrentPage - 1) * this.mesPageSize;
    const mesEndIndex = mesStartIndex + this.mesPageSize;
    this.mesDemandesPaged = this.mesDemandesFiltrees.slice(mesStartIndex, mesEndIndex);
  }

  showSuccessToast(message: string): void {
    this.toastMessage = message;
    this.toastType = 'success';
