  // Report and statistics methods
  onRapportDatesChanged(): void {
    if (this.rapportDateDebut && this.rapportDateFin) {
      this.calculateStatistics();
      this.generateDemandesParMois();
    }
  }

  private calculateStatistics(): void {
    // Calculate percentages based on current data
    if (this.totalDemandes > 0) {
      this.statusPercentEnAttente = Math.round((this.enAttente / this.totalDemandes) * 100);
      this.statusPercentEnCours = Math.round((this.enCours / this.totalDemandes) * 100);
      this.statusPercentResolues = Math.round((this.resolues / this.totalDemandes) * 100);
    } else {
      this.statusPercentEnAttente = 0;
      this.statusPercentEnCours = 0;
      this.statusPercentResolues = 0;
    }
  }

  private generateDemandesParMois(): void {
    // Generate sample data for monthly demands
    this.demandesParMois = [
      { mois: 'Janvier', total: 25, enAttente: 5, enCours: 10, resolues: 10 },
      { mois: 'Février', total: 30, enAttente: 8, enCours: 12, resolues: 10 },
      { mois: 'Mars', total: 22, enAttente: 3, enCours: 9, resolues: 10 },
      { mois: 'Avril', total: 35, enAttente: 7, enCours: 15, resolues: 13 },
      { mois: 'Mai', total: 28, enAttente: 6, enCours: 11, resolues: 11 },
      { mois: 'Juin', total: 32, enAttente: 9, enCours: 13, resolues: 10 }
    ];
    
    this.maxDemandesParMois = Math.max(...this.demandesParMois.map(d => d.total));
  }

  // Preventive maintenance filtering methods
  setPreventiveStatutFilter(statut: string): void {
    this.preventiveStatutFilter = statut;
    this.applyPreventiveFilter();
  }

  private applyPreventiveFilter(): void {
    if (this.preventiveStatutFilter === 'TOUS') {
      this.filteredMaintenancesPreventives = [...this.maintenancesPreventives];
    } else {
      this.filteredMaintenancesPreventives = this.maintenancesPreventives.filter(
        maintenance => maintenance.statut === this.preventiveStatutFilter
      );
    }
  }

